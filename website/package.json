{
  "name": "blog-website",
  "private": true,
  "type": "module",
  "scripts": {
    "extract": "tsx scripts/extract-posts.ts",
    "dev": "npm run extract && vite",
    "build": "npm run extract && tsc -p tsconfig.json --noEmit && vite build && tsx scripts/generate-seo.ts",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "prism-react-renderer": "^2.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5"
  }
}
